# ==============================================================================
# NAYAK SUITE - SHARED CONFIGURATION TEMPLATE (.env.example)
# Rename this file to .env in production / local dev environment.
# ==============================================================================

# --- FRONTEND SETTINGS (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_ENV=development

# --- BACKEND SETTINGS (apps/api) ---
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# --- DATABASE SETTINGS ---
DATABASE_URL=sqlite+aiosqlite:///./nayak.db

# --- AI & LLM PROVIDER CREDENTIALS ---
# Add your corresponding keys for agentic workflows in Nyaybandhu & VicharakBandhu
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
