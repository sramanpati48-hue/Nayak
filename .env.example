# ==============================================================================
# NAYAK SUITE - SHARED CONFIGURATION TEMPLATE (.env.example)
# Rename this file to .env in production / local dev environment.
# ==============================================================================

# --- FRONTEND SETTINGS (apps/web) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_ENV=development

# Clerk (create a free app at https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- BACKEND SETTINGS (apps/api) ---
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# --- DATABASE SETTINGS ---
DATABASE_URL=sqlite+aiosqlite:///./nayak.db

# --- AI & LLM PROVIDER CREDENTIALS ---
# Add your corresponding keys for agentic workflows in Nyaybandhu & VicharakBandhu
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- CLERK JWT VERIFICATION (apps/api) ---
# From Clerk Dashboard → API Keys → Advanced → JWT Issuer
CLERK_ISSUER=https://your-instance.clerk.accounts.dev
CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Same secret key as web (for updating user metadata)
CLERK_SECRET_KEY=sk_test_...
AUTH_ALLOW_HEADER_FALLBACK=true
